# GenSafe B2B - Environment Variables
# Copy this file to backend/.env and fill values for your environment.

# Required: Gemini AI
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative key name supported:
# GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Security (change in production)
JWT_SECRET=gensafe-secret-key-2024-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_HARDENED_EXPIRE_MINUTES=120
ENABLE_SECURITY_HARDENING=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
SECURITY_HEADERS_ENABLED=true

# App settings
ENVIRONMENT=development
UPLOAD_DIR=./static/uploads
TESSERACT_CMD=

# Database (default SQLite for local development)
DATABASE_URL=sqlite+aiosqlite:///./gensafe.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/gensafe

# Risk thresholds
RISK_AUTO_APPROVE=25.0
RISK_HUMAN_REVIEW=60.0
RISK_AUTO_BLOCK=80.0

# Verification agent policy controls
# False keeps current legacy decision behavior
ENABLE_VERIFICATION_RULES=false
VERIFICATION_HIGH_VALUE_THRESHOLD=10000

# Workflow health monitor thresholds
PROCESSING_SLA_MINUTES=30
HEALTH_QUEUE_WARNING=50
HEALTH_QUEUE_CRITICAL=200
HEALTH_FAILED_JOBS_WARNING=5
HEALTH_FAILED_JOBS_CRITICAL=15

# Job dispatch
JOB_DISPATCH_MODE=background

# Object storage (optional S3 archive)
OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_S3_BUCKET=
OBJECT_STORAGE_S3_PREFIX=invoices/
OBJECT_STORAGE_S3_REGION=
OBJECT_STORAGE_PUBLIC_BASE_URL=

# Escalation and notifications
TASK_ESCALATION_HOURS=24
NOTIFICATION_WEBHOOK_URL=

# Cache
CACHE_MODE=memory
REDIS_URL=redis://localhost:6379/0
CONTEXT_CACHE_TTL_SECONDS=300

# Audit retention / integrity
AUDIT_RETENTION_DAYS=365
ENABLE_AUDIT_RETENTION=false
ALLOW_AUDIT_PURGE=false
AUDIT_ARCHIVE_DIR=./static/audit-archive

# ERP OAuth defaults (optional overrides)
# QuickBooks default callback path: /api/v1/integration/quickbooks/callback
# Xero default callback path: /api/v1/integration/xero/callback
